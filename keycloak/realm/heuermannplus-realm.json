{
  "realm": "heuermannplus",
  "enabled": true,
  "displayName": "HeuermannPlus",
  "registrationAllowed": false,
  "passwordPolicy": "length(8) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1)",
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "editUsernameAllowed": true,
  "duplicateEmailsAllowed": false,
  "defaultRoles": [
    "offline_access",
    "uma_authorization"
  ],
  "roles": {
    "realm": [
      {
        "name": "registration-pending",
        "description": "User completed registration but has not verified the email yet."
      },
      {
        "name": "app-user",
        "description": "Base role for verified application users."
      },
      {
        "name": "group-member",
        "description": "Role for users that belong to a group."
      },
      {
        "name": "group-admin",
        "description": "Role for users that manage a group."
      },
      {
        "name": "app-admin",
        "description": "Administrative role for the whole application."
      }
    ]
  },
  "clients": [
    {
      "clientId": "heuermannplus-frontend",
      "name": "HeuermannPlus Frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "heuermannplus-frontend-secret",
      "redirectUris": [
        "http://localhost:3000/api/auth/callback/keycloak",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "backchannel.logout.session.required": "true",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "roles",
        "profile",
        "email",
        "basic"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "heuermannplus-registration-service",
      "name": "HeuermannPlus Registration Service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "heuermannplus-registration-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "frontchannelLogout": false
    },
    {
      "clientId": "heuermannplus-backend",
      "name": "HeuermannPlus Backend",
      "enabled": true,
      "protocol": "openid-connect",
      "bearerOnly": true
    }
  ],
  "users": [
    {
      "username": "service-account-heuermannplus-registration-service",
      "enabled": true,
      "serviceAccountClientId": "heuermannplus-registration-service",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "query-users",
          "query-clients",
          "view-realm",
          "view-users",
          "view-clients"
        ]
      }
    }
  ]
}
