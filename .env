COMPOSE_PROJECT_NAME=heuermannplus

FRONTEND_PORT=3000
BACKEND_PORT=8080
KEYCLOAK_PORT=8081
APP_POSTGRES_PORT=5432
KEYCLOAK_POSTGRES_PORT=5433

APP_DB_NAME=heuermannplus
