root = true

[*.{js,jsx,ts,tsx,kt,kts,java,groovy,gradle,md,yml,yaml,json,sql,env}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{kt,kts,java,groovy,gradle}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
